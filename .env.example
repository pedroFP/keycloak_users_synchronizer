KEYCLOAK_BASE_URL=http://localhost:8080

KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_CLIENT_SECRET=mysecret

KEYCLOAK_REALM=myrealm

# Check app/keycloak/service/access_token_generator.rb to see which credentials to use
# KEYCLOAK_ADMIN_USERNAME=admin
# KEYCLOAK_ADMIN_PASSWORD=admin

KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=admin

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CLIENT_ID=keycloak_users_synchronizer

KARAFKA_ENV=development