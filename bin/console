#!/usr/bin/env ruby
# frozen_string_literal: true

require 'irb'
require 'irb/completion'
require_relative '../keycloak'

puts "Keycloak console — all classes loaded."
puts "  Keycloak::AccessTokenGenerator.call"
puts "  Keycloak::Realm.new('myrealm').users"
puts

def reload!
  root = File.expand_path('..', __dir__)
  load File.join(root, 'util', 'model_serializer.rb')
  Dir[File.join(root, 'app', '**', '*.rb')].each { |f| load f }
  true
end

IRB.start(__FILE__)
