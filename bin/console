#!/usr/bin/env ruby
# frozen_string_literal: true

require 'irb'
require 'irb/completion'

begin
  require_relative '../keycloak'
rescue Bundler::GemNotFound, LoadError => e
  puts
  puts '  ------------------------------------------'
  puts '  Missing gems — run the following first:'
  puts
  puts '    bundle install'
  puts
  puts "  Error: #{e.message}"
  puts '  ------------------------------------------'
  puts
  exit 1
end

WIDTH = 52

def box_line(content = '')
  pad = WIDTH - content.length - 2
  "  | #{content}#{' ' * [pad, 0].max} |"
end

def divider
  "  +#{'-' * (WIDTH - 2)}+"
end

puts
puts divider
puts box_line
puts box_line('  Keycloak Users Synchronizer')
puts box_line
puts divider
puts box_line
puts box_line('  Classes loaded')
puts box_line('    Keycloak::User')
puts box_line('    Keycloak::UserGroup')
puts box_line('    Keycloak::UserApi')
puts box_line('    Keycloak::UserGroupApi')
puts box_line('    Keycloak::Service::AccessTokenGenerator')
puts box_line
puts box_line('  Helpers')
puts box_line('    reload!  ->  reload all app classes')
puts box_line
puts box_line('  Example')
puts box_line('    Keycloak::User.where(first: 1).limit(100)')
puts box_line
puts divider
puts

def reload!
  root = File.expand_path('..', __dir__)
  # First util
  Dir[File.join(root, 'util', '**', '*.rb')].each { |f| load f }

  Dir[File.join(root, 'app', '**', '*.rb')].each { |f| load f }
  true
end

IRB.start(__FILE__)
